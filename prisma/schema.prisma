generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String         @id @default(uuid())
  name                  String?
  email                 String         @unique
  password              String?
  avatar                String?
  provider              String         @default("email")
  role                  String         @default("SEEKER")
  createdAt             DateTime       @default(now())
  bookingsAsSeeker      Booking[]      @relation("SeekerBookings")
  bookmarks             Bookmark[]
  conversationsAsSeeker Conversation[] @relation("SeekerConversations")
  expertProfile         ExpertProfile?
  notifications         Notification[]
  requirements          Requirement[]
}

model ExpertProfile {
  id                    String                 @id @default(uuid())
  userId                String                 @unique
  title                 String?
  bio                   String?
  expertise             String?
  yearsExperience       String?
  skills                String[]               @default([])
  company               String?
  status                String                 @default("PENDING_APPROVAL")
  hourlyRate            Int?                   @default(0)
  usefulnessScore       Int                    @default(0)
  requirementsReceived  Int                    @default(0)
  approvedDate          DateTime?
  linkedinUrl           String?
  behanceUrl            String?
  websiteUrl            String?
  allowsDirectBooking   Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  bookingsAsExpert      Booking[]              @relation("ExpertBookings")
  bookmarksReceived     Bookmark[]
  conversationsAsExpert Conversation[]         @relation("ExpertConversations")
  user                  User                   @relation(fields: [userId], references: [id])
  requirementRecipients RequirementRecipient[]
  slots                 Slot[]
}

model Requirement {
  id                 String                 @id @default(uuid())
  title              String
  seekerId           String
  companyName        String?
  companyStage       String?
  problemDescription String
  category           String?
  timeCommitment     String?
  offerType          String?
  offerDetails       String?
  additionalContext  String?
  attachments        String?
  isDraft            Boolean                @default(false)
  isPublic           Boolean                @default(true)
  status             String                 @default("open")
  createdAt          DateTime               @default(now())
  conversations      Conversation[]
  seeker             User                   @relation(fields: [seekerId], references: [id])
  recipients         RequirementRecipient[]
  slots              Slot[]
}

model RequirementRecipient {
  id            String        @id @default(uuid())
  requirementId String
  expertId      String
  status        String        @default("pending")
  rejectionNote String?
  createdAt     DateTime      @default(now())
  expert        ExpertProfile @relation(fields: [expertId], references: [id])
  requirement   Requirement   @relation(fields: [requirementId], references: [id])

  @@unique([requirementId, expertId])
}

model Bookmark {
  id        String        @id @default(uuid())
  seekerId  String
  expertId  String
  createdAt DateTime      @default(now())
  expert    ExpertProfile @relation(fields: [expertId], references: [id])
  seeker    User          @relation(fields: [seekerId], references: [id])
  tags      BookmarkTag[]

  @@unique([seekerId, expertId])
}

model BookmarkTag {
  id         String   @id @default(uuid())
  bookmarkId String
  name       String
  bookmark   Bookmark @relation(fields: [bookmarkId], references: [id])
}

model Slot {
  id            String        @id @default(uuid())
  expertId      String
  requirementId String?
  date          String
  time          String
  timezone      String
  isBooked      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  booking       Booking?
  expert        ExpertProfile @relation(fields: [expertId], references: [id])
  requirement   Requirement?  @relation(fields: [requirementId], references: [id])
}

model Booking {
  id        String        @id @default(uuid())
  slotId    String        @unique
  seekerId  String
  expertId  String
  status    String        @default("confirmed")
  meetLink  String?
  createdAt DateTime      @default(now())
  expert    ExpertProfile @relation("ExpertBookings", fields: [expertId], references: [id])
  seeker    User          @relation("SeekerBookings", fields: [seekerId], references: [id])
  slot      Slot          @relation(fields: [slotId], references: [id])
}

model Conversation {
  id                   String        @id @default(uuid())
  seekerId             String
  expertId             String
  relatedRequirementId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  expert               ExpertProfile @relation("ExpertConversations", fields: [expertId], references: [id])
  relatedRequirement   Requirement?  @relation(fields: [relatedRequirementId], references: [id])
  seeker               User          @relation("SeekerConversations", fields: [seekerId], references: [id])
  messages             Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
